# ── NocoDB (self-hosted) ──────────────────────────────────────────────────────
NOCODB_URL=http://localhost:8080
NOCODB_API_KEY=your_nocodb_api_key
NOCODB_PROJECT_ID=your_project_id

# Tablas (se generan automáticamente via POST /api/setup)
NOCODB_TABLE_CAMPAIGNS=
NOCODB_TABLE_METRICS=
NOCODB_TABLE_SYNC_LOG=
NOCODB_TABLE_ADSETS=
NOCODB_TABLE_ADS=
NOCODB_TABLE_CRM_STAGES=
NOCODB_TABLE_CRM_USERS=
NOCODB_TABLE_CRM_LEADS=
NOCODB_TABLE_CRM_ACTIVITIES=

# ── Meta Ads ──────────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_XXXXXXXXXX
META_AD_ACCOUNT_IDS=act_XXXXXXXXXX,act_YYYYYYYYYY
META_API_VERSION=v19.0

# ── Google Ads ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_CUSTOMER_ID=
GOOGLE_LOGIN_CUSTOMER_ID=

# ── TikTok Ads ────────────────────────────────────────────────────────────────
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# ── Config ────────────────────────────────────────────────────────────────────
SYNC_INTERVAL_HOURS=6
USE_MOCK_DATA=false

# URL base de la app
# - Local:   http://localhost:4000
# - Vercel:  https://tu-app.vercel.app  (o dejar vacío, se usa VERCEL_URL automáticamente)
NEXTAUTH_URL=http://localhost:4000

# Cron security — OBLIGATORIO. Genera una clave aleatoria y agrégala en Vercel Dashboard.
# Genera con: openssl rand -hex 32
CRON_SECRET=

# ── Autenticación del Dashboard (Basic Auth) ──────────────────────────────────
# OBLIGATORIO. Protege el acceso al dashboard y todas las rutas API.
# Agrega estas variables también en Vercel Dashboard → Settings → Environment Variables.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=cambia_esta_contraseña_segura
