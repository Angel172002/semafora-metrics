# NocoDB (self-hosted)
NOCODB_URL=http://localhost:8080
NOCODB_API_KEY=your_nocodb_api_key
NOCODB_TABLE_CAMPAIGNS=campaigns
NOCODB_TABLE_METRICS=daily_metrics
NOCODB_TABLE_SYNC_LOG=sync_log

# Meta Ads — https://developers.facebook.com/docs/marketing-apis
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_XXXXXXXXXX

# Google Ads — https://developers.google.com/google-ads/api/docs/start
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_CUSTOMER_ID=

# TikTok Ads — https://business-api.tiktok.com/portal/docs
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# Config
SYNC_INTERVAL_HOURS=6
USE_MOCK_DATA=true
NEXTAUTH_URL=http://localhost:4000
